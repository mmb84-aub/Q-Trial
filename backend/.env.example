# Choose provider via CLI flag; keys only needed for providers you use.

# OpenAI (ChatGPT)
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini

# Gemini — supports comma-separated keys for automatic daily-quota rotation:
# GEMINI_API_KEY=key_from_project1,key_from_project2,key_from_project3
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash

# Claude
ANTHROPIC_API_KEY=your_anthropic_key
CLAUDE_MODEL=claude-opus-4-6

# OpenRouter (supports multiple providers; see https://openrouter.ai/docs for details)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=openai/gpt-4o

# NCBI E-utilities (optional, increases PubMed rate limit from 3/sec to 10/sec)
NCBI_API_KEY=your_ncbi_key

# Semantic Scholar (optional, increases rate limit; get a free key at https://www.semanticscholar.org/product/api#api-key-form)
S2_API_KEY=your_s2_key

# Agent settings
MAX_AGENT_ITERATIONS=25
MAX_TOOL_RESULT_CHARS=4000

AWS_ACCESS_KEY_ID=your key id
AWS_SECRET_ACCESS_KEY=your secret access key
AWS_REGION=eu-north-1
AWS_BEDROCK_MODEL=anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_BEDROCK_MAX_TOKENS=4096
